name: SMTP_Project

python_env: python_env.yaml

entry_points:
  main:
    parameters:
      learning_rate: {type: float, default: 0.1}
      n_estimators: {type: int, default: 100}
    command: "python src/train.py --learning_rate {learning_rate} --n_estimators {n_estimators}"
  rede_neural:
    parameters:
      learning_rate: {type: float, default: 0.001}
      hidden_size: {type: int, default: 4}
      num_epochs: {type: int, default: 200}
    command: "python src/rede_neural/train.py --learning_rate {learning_rate} --hidden_size {hidden_size} --num_epochs {num_epochs}"
  test:
    command: "pytest tests/test_pipeline.py"
